
{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "A church member",
      "type": "object",
      "properties": {
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "branch_id": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Visitor", "Probation"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["first_name", "last_name", "branch_id", "status"]
    },
    "TitheRecord": {
      "title": "Tithe Record",
      "description": "A record of a tithe payment",
      "type": "object",
      "properties": {
        "member_id": { "type": "string" },
        "amount": { "type": "number" },
        "payment_date": { "type": "string", "format": "date" },
        "payment_method": { "type": "string", "enum": ["Cash", "Bank Transfer", "MoMo", "Cheque"] },
        "service_type": { "type": "string" },
        "recorded_by": { "type": "string" },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["member_id", "amount", "payment_date", "payment_method", "recorded_by"]
    },
    "MinistryReport": {
      "title": "Ministry Report",
      "description": "A quarterly, mid-year or annual report for a ministry",
      "type": "object",
      "properties": {
        "ministry_id": { "type": "string" },
        "report_type": { "type": "string", "enum": ["Quarterly", "Mid-year", "Annual"] },
        "year": { "type": "number" },
        "period": { "type": "string" },
        "achievements": { "type": "string" },
        "challenges": { "type": "string" },
        "goals_next_period": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Submitted", "Approved"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["ministry_id", "report_type", "year", "period", "status"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of church members"
    },
    "/tithe_records/{titheId}": {
      "schema": "TitheRecord",
      "description": "Collection of tithe payment records"
    },
    "/ministry_reports/{reportId}": {
      "schema": "MinistryReport",
      "description": "Collection of ministry reports"
    }
  }
}
